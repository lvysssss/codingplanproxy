# Anthropic API 上游地址（固定）
BASE_URL=https://api.anthropic.com

# Anthropic API Key（必填）
API_KEY=sk-ant-api03-xxxxxxxxxxxx

# 固定使用的模型名称（默认模型，请求未指定时使用）
MODEL_NAME=claude-sonnet-4-20250514

# 可用模型列表（逗号分隔，客户端请求时可从中选择）
# 如果不配置，默认只包含 MODEL_NAME
AVAILABLE_MODELS=claude-sonnet-4-20250514,claude-opus-4-20250514,claude-haiku-4-20250514

# 默认 max_tokens
DEFAULT_MAX_TOKENS=16384

# 可选：注入的 system prompt（留空不注入）
SYSTEM_PROMPT=

# 代理服务端口
PORT=8000

# 可选：客户端调用代理时需提供的 API Key（留空不校验）
PROXY_API_KEY=
