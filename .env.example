# Anthropic API 上游地址（固定）
BASE_URL=https://api.anthropic.com

# Anthropic API Key（必填）
API_KEY=sk-ant-api03-xxxxxxxxxxxx

# 可用模型列表（逗号分隔，留空则仅使用远端自动获取的模型）
# 如果上游有模型未在 Models API 中展示但实际可用，可手动添加
AVAILABLE_MODELS=

# 默认 max_tokens
DEFAULT_MAX_TOKENS=16384

# 可选：注入的 system prompt（留空不注入）
SYSTEM_PROMPT=

# 代理服务端口
PORT=8000

# 可选：客户端调用代理时需提供的 API Key（留空不校验）
PROXY_API_KEY=
